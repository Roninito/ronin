kata alpaca-portfolio-sync v1
  requires skill alpaca

  initial fetch

  # Phase 1: Fetch all data from Alpaca API
  phase fetch
    run skill alpaca
    next persist

  # Phase 2: Write data to portfolio-vault/ for the dashboard
  phase persist
    run skill alpaca
    next done

  # Phase 3: Done
  phase done
    run skill alpaca
    complete
